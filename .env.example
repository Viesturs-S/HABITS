# Optional: dev + serverless — copy to `.env.local` (never commit `.env.local`)
#
# Generate a long random secret, use the SAME value in Vercel Project → Environment Variables
# as HABIT_SYNC_SECRET. Paste that same secret into the app’s “Sync token” field on each device.
HABIT_SYNC_SECRET=

# From Vercel → Storage → Redis (Upstash) — “Connect to Project” adds these automatically on deploy
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rare: if the static app is hosted somewhere other than your API (leave unset for normal Vercel SPA + /api)
# VITE_HABITS_API_BASE=https://your-deployment.vercel.app
