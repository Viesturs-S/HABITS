# Copy to `.env.local` for local dev (never commit `.env.local`)

# Server + matching client secret (use the SAME random string for both on Vercel Production).
# `VITE_*` is baked into the browser bundle — fine for a personal app; anyone with the site can read it.
HABIT_SYNC_SECRET=
VITE_HABIT_SYNC_SECRET=

# From Vercel → Storage → Redis (Upstash), linked to this project
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rare: different API host than the static site
# VITE_HABITS_API_BASE=https://your-deployment.vercel.app
