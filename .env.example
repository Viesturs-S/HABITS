# Copy to `.env.local` for local dev (never commit `.env.local`)

# Server secret (never exposed to browser). Must match VITE_HABIT_SYNC_SECRET if you use one-tap Sync.
HABIT_SYNC_SECRET=

# Same value as HABIT_SYNC_SECRET — embedded in the JS bundle at build time (personal apps only).
VITE_HABIT_SYNC_SECRET=

# Upstash / Vercel Redis — either pair works for our serverless code:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# …or the names Vercel adds when you connect the Redis integration:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Rare: different API host than the static site
# VITE_HABITS_API_BASE=https://your-deployment.vercel.app
